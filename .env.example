# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL (required for user auth — must be postgres:// or postgresql://, not MongoDB)
DATABASE_URL=postgresql://user:password@localhost:5432/verified_portal

# Drizzle: npm run db:generate  then  npm run db:migrate

# JWT (set strong secrets in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional
# LEAD_API_KEY=
# SERVER_URL=https://api.example.com
